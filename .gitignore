# =============================================
# Saqr (الصقر) — Git Ignore Rules
# =============================================

# Environment variables — NEVER commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.bak
*~

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test coverage
.coverage
htmlcov/
coverage.xml
*.cover

# Supabase CLI
.supabase/
supabase/.temp/

# Temporary
*.tmp
*.temp
node_modules
